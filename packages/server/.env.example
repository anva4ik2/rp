PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gta_rp
JWT_SECRET=replace_with_long_secret_32_chars_minimum
ADMIN_TOKEN=replace_admin_token
CORS_ORIGINS=https://your-launcher-domain.com,https://your-admin-panel.com
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=200
TRUST_PROXY=true

# Optional: first user that registers with this email is promoted to admin level 5 (founder).
BOOTSTRAP_FOUNDER_EMAIL=

# Optional: default model code for the starter vehicle granted on character creation.
STARTER_VEHICLE_MODEL=blista
