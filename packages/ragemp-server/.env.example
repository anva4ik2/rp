# URL of the backend API (Railway, Docker or localhost).
API_BASE_URL=http://localhost:3000

# Used as the password component when register/login is delegated to the bridge.
# Make it long & random in production.
AUTH_SALT=replace_with_long_random_string

# Admin token of the backend API. Used by the bridge to poll /admin/pending
# (and only by the bridge — players never see this).
ADMIN_TOKEN=replace_admin_token
