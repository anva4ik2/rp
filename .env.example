# =============================================================================
# GTA RP Core — Environment Variables Example
# Copy to .env.local for local dev, or set in Railway Dashboard → Variables
# =============================================================================

# ────────────────────────── SERVICE 1: Express API (packages/server) ──────────
PORT=4000
DATABASE_URL=postgresql://postgres:password@localhost:5432/rp
JWT_SECRET=change-me-min-32-characters-long-secret-key
ADMIN_TOKEN=change-me-admin-token-for-ragemp-bridge
BOOTSTRAP_FOUNDER_EMAIL=founder@example.com
STARTER_VEHICLE_MODEL=asea
CORS_ORIGINS=*
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=20
TRUST_PROXY=true

# ────────────────────────── SERVICE 2: PostgreSQL ─────────────────────────────
# Railway auto-creates DATABASE_URL when PostgreSQL plugin is added.
# For local Docker: postgresql://postgres:postgres@localhost:5432/rp

# ────────────────────────── SERVICE 3: RAGE MP Server (packages/ragemp-server) ─
API_BASE_URL=http://localhost:4000
ADMIN_TOKEN=change-me-same-as-ADMIN_TOKEN-above
AUTH_SALT=ragemp-auth-salt-change-me
ADMIN_POLL_MS=3000
POSITION_SAVE_MS=30000

# ────────────────────────── SERVICE 4: RAGE MP Client (packages/ragemp-client) ─
# Build-time only — set before running `npm run build` in client package
# CLIENT_API_BASE_URL=http://localhost:4000

# ────────────────────────── SERVICE 5: CEF UI (packages/ragemp-cef) ─────────
# No env vars — all config comes from client via mp.trigger / window.dispatchEvent
# CEF never talks to HTTP API directly.

# ────────────────────────── OPTIONAL / DEBUG ───────────────────────────────────
# NODE_ENV=production
# LOG_LEVEL=debug
